Retry short reads in expert_load instead of treating them as fatal.

POSIX allows short reads on regular files under memory pressure.
Also fixes misleading "pread expert: Success" error message where
perror() prints errno from a prior successful syscall.

--- a/c/glm.c
+++ b/c/glm.c
@@ -1323,6 +1323,17 @@
  * pread error aborts the process. fatal=0 (speculative pilot only): the same
  * errors instead abandon the load and return -1 without touching s->eid, so a
  * mispredicted cross-layer prefetch can never kill the server. */
+static ssize_t pread_full(int fd, void *buf, size_t count, off_t offset){
+    size_t done=0;
+    while(done<count){
+        ssize_t r=pread(fd, (char*)buf+done, count-done, offset+(off_t)done);
+        if(r<0) return r;
+        if(r==0) break;
+        done+=r;
+    }
+    return (ssize_t)done;
+}
+
